# Copy to `.env.local` and fill only the variables your project uses.
# `skills/worktree` symlinks `.env.local` into worktrees, so project-local
# workflow helpers stay available everywhere.

# ═══════════════════════════════════════════
# VSTACK / WORKTREE
# ═══════════════════════════════════════════
# WORKTREE_SYMLINKS=".cache"
# WORKTREE_COPIES=".tooling/settings.json"
# WORKTREE_DEFAULT_BRANCH="main"

# Optional command aliases used by portable orchestration workflows.
# Set these if your harness/session does not inject them for you.
# ISSUE_CLI="./scripts/issue-tracker"
# GIT_HOST_CLI="./scripts/git-host"
# WORKTREE_CLI="./scripts/worktree"
# VALIDATE_CMD="make validate"
# DECISIONS_CMD="./scripts/decisions"

# ═══════════════════════════════════════════
# LINEAR
# ═══════════════════════════════════════════
# LINEAR_API_KEY=""
# LINEAR_TEAM="MyTeam"
# LINEAR_FORMAT="safe"
# LINEAR_TEAM_PREFIX="PROJ"

# ═══════════════════════════════════════════
# GITHUB
# ═══════════════════════════════════════════
# GH_BOT_TOKEN=""
# GH_BOT_USERNAME="automation[bot]"
# GH_ISSUE_PATTERN="[A-Z]+-[0-9]+"
# GH_VERIFY_CMD="make verify"
# BOT_REVIEWERS="review-bot-a[bot],review-bot-b[bot]"
# BOT_CHECK_NAME="review-bot"

# ═══════════════════════════════════════════
# VISUAL QA WORKFLOW HELPERS
# ═══════════════════════════════════════════
# These variables are optional. They complement `visual-qa.conf`; they do not
# replace it. Use them when your project has multiple UI targets or companion
# validation commands that the generic workflows should call.
#
# Example target selector:
# VISUAL_QA_TARGET_CMD="./scripts/select-visual-target"
#
# Example representative fixture for map-capable targets:
# VISUAL_QA_FIXTURE="path/to/layout-fixture"
#
# Example runtime smoke test for screenshot/OCR-only targets:
# VISUAL_QA_SMOKE_CMD="./scripts/ui-smoke"
#
# Example broader visual regression battery:
# VISUAL_QA_BATTERY_CMD="./scripts/ui-battery"
#
# Example baseline routing helper for submit-pr:
# VISUAL_QA_BASELINE_CMD="./scripts/capture-visual-baselines"
