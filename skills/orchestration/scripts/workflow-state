#!/usr/bin/env bash
# Workflow state file management for multi-agent orchestration
# Usage: workflow-state <command> <issue_id> [args...]

set -euo pipefail

STATE_DIR="${ORCH_STATE_DIR:-tmp}"
STATE_PREFIX="workflow-state"

get_state_file() {
    local issue_id="$1"
    echo "${STATE_DIR}/${STATE_PREFIX}-${issue_id}.json"
}

ensure_state_exists() {
    local state_file="$1"
    if [[ ! -f "$state_file" ]]; then
        echo "Error: State file not found: $state_file" >&2
        echo "Run 'workflow-state init <issue_id>' first" >&2
        exit 1
    fi
}

# Atomic update: flock + write to temp, validate, move
# Uses flock to serialize concurrent writes and prevent state corruption.
atomic_update() {
    local state_file="$1"
    local jq_expr="$2"
    local lock_file="${state_file}.lock"
    local tmp_file="${state_file}.tmp"

    (
        flock -w 10 200 || { echo "Error: could not acquire lock on $lock_file" >&2; exit 1; }

        if ! jq "$jq_expr" "$state_file" > "$tmp_file" 2>&1; then
            echo "Error: jq expression failed: $jq_expr" >&2
            rm -f "$tmp_file"
            exit 1
        fi

        # Validate output is valid JSON
        if ! jq empty "$tmp_file" 2>/dev/null; then
            echo "Error: jq produced invalid JSON" >&2
            rm -f "$tmp_file"
            exit 1
        fi

        mv "$tmp_file" "$state_file"
    ) 200>"$lock_file"
}

cmd_init() {
    local issue_id="$1"
    shift

    local agent="" worktree="" branch="" team_name="" qa_labels="[]" sub_issues="[]"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --agent) agent="$2"; shift 2 ;;
            --worktree) worktree="$2"; shift 2 ;;
            --branch) branch="$2"; shift 2 ;;
            --team) team_name="$2"; shift 2 ;;
            --qa-labels) qa_labels="$2"; shift 2 ;;
            --sub-issues) sub_issues="$2"; shift 2 ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
    done

    mkdir -p "$STATE_DIR"
    local state_file
    state_file=$(get_state_file "$issue_id")

    # Build JSON safely with jq --arg to handle special characters
    jq -n \
      --arg issue_id "$issue_id" \
      --arg agent "$agent" \
      --arg worktree "$worktree" \
      --arg branch "$branch" \
      --arg team_name "$team_name" \
      --argjson sub_issues "$sub_issues" \
      --argjson qa_labels "$qa_labels" \
      '{
        issue_id: $issue_id,
        sub_issues: $sub_issues,
        agent: $agent,
        worktree: $worktree,
        branch: $branch,
        team_name: $team_name,
        qa_labels: $qa_labels,
        child_sessions: {},
        cycles: 0,
        json_paths: [],
        fixed_items: [],
        escalated_items: [],
        audit_issues_created: [],
        pr_review_baseline: null,
        pr_comment_review: {
          iterations: 0,
          fixes: [],
          issues_created: [],
          skipped: []
        }
      }' > "$state_file"

    echo "$state_file"
}

cmd_get() {
    local issue_id="$1"
    local jq_path="${2:-.}"

    local state_file
    state_file=$(get_state_file "$issue_id")
    ensure_state_exists "$state_file"

    jq -r "$jq_path" "$state_file"
}

cmd_update() {
    local issue_id="$1"
    local jq_expr="$2"

    local state_file
    state_file=$(get_state_file "$issue_id")
    ensure_state_exists "$state_file"

    atomic_update "$state_file" "$jq_expr"
}

cmd_append() {
    local issue_id="$1"
    local field="$2"
    local value="$3"

    local state_file
    state_file=$(get_state_file "$issue_id")
    ensure_state_exists "$state_file"

    # Handle nested fields (e.g., pr_comment_review.fixes)
    if [[ "$value" == "{"* ]] || [[ "$value" == "["* ]]; then
        # JSON object or array - use as-is
        atomic_update "$state_file" ".${field} += [${value}]"
    else
        # String value - use --arg for safe quoting (handles embedded quotes)
        local tmp_file="${state_file}.tmp"
        local lock_file="${state_file}.lock"
        (
            flock -w 10 200 || { echo "Error: could not acquire lock" >&2; exit 1; }
            jq --arg v "$value" ".${field} += [\$v]" "$state_file" > "$tmp_file" 2>&1 || { rm -f "$tmp_file"; exit 1; }
            jq empty "$tmp_file" 2>/dev/null || { echo "Error: invalid JSON" >&2; rm -f "$tmp_file"; exit 1; }
            mv "$tmp_file" "$state_file"
        ) 200>"$lock_file"
    fi
}

cmd_increment() {
    local issue_id="$1"
    local field="$2"

    local state_file
    state_file=$(get_state_file "$issue_id")
    ensure_state_exists "$state_file"

    atomic_update "$state_file" ".${field} += 1"
}

cmd_set() {
    local issue_id="$1"
    local field="$2"
    local value="$3"

    local state_file
    state_file=$(get_state_file "$issue_id")
    ensure_state_exists "$state_file"

    if [[ "$value" == "{"* ]] || [[ "$value" == "["* ]] || [[ "$value" == "null" ]] || [[ "$value" == "true" ]] || [[ "$value" == "false" ]] || [[ "$value" =~ ^[0-9]+$ ]]; then
        # JSON object, array, null, boolean, or number - use as-is
        atomic_update "$state_file" ".${field} = ${value}"
    else
        # String value - use --arg for safe quoting (handles embedded quotes)
        local tmp_file="${state_file}.tmp"
        local lock_file="${state_file}.lock"
        (
            flock -w 10 200 || { echo "Error: could not acquire lock" >&2; exit 1; }
            jq --arg v "$value" ".${field} = \$v" "$state_file" > "$tmp_file" 2>&1 || { rm -f "$tmp_file"; exit 1; }
            jq empty "$tmp_file" 2>/dev/null || { echo "Error: invalid JSON" >&2; rm -f "$tmp_file"; exit 1; }
            mv "$tmp_file" "$state_file"
        ) 200>"$lock_file"
    fi
}

cmd_path() {
    local issue_id="$1"
    get_state_file "$issue_id"
}

cmd_exists() {
    local issue_id="$1"
    local state_file
    state_file=$(get_state_file "$issue_id")
    [[ -f "$state_file" ]]
}

cmd_help() {
    cat << 'EOF'
Usage: workflow-state <command> <issue_id> [args...]

Commands:
  init <issue_id> [options]     Create new state file
    --agent <name>              Primary agent
    --worktree <path>           Worktree path
    --branch <name>             Branch name
    --team <name>               Team name (optional)
    --qa-labels <json_array>    QA labels (default: [])
    --sub-issues <json_array>   Sub-issue IDs (default: [])

  get <issue_id> [jq_path]      Read value (default: entire state)
  update <issue_id> <jq_expr>   Run arbitrary jq expression
  append <issue_id> <field> <value>   Append to array field
  increment <issue_id> <field>  Increment numeric field
  set <issue_id> <field> <value>  Set field value
  path <issue_id>               Print state file path
  exists <issue_id>             Exit 0 if exists, 1 if not

Examples:
  workflow-state init PROJ-123 --agent rust --worktree /tmp/wt
  workflow-state get PROJ-123 .cycles
  workflow-state increment PROJ-123 cycles
  workflow-state increment PROJ-123 pr_comment_review.iterations
  workflow-state append PROJ-123 json_paths "review.json"
  workflow-state append PROJ-123 fixed_items '{"description":"Fix","commit":"abc"}'
  workflow-state set PROJ-123 pr_review_baseline '{"last_ts":"2026-01-28","last_threads":2}'
  workflow-state update PROJ-123 '.fixed_items | map(select(.source == "qa-review"))'

Environment:
  ORCH_STATE_DIR    Override state directory (default: tmp)

Dependencies:
  jq               JSON processing
  flock             File locking (util-linux)
EOF
}

# Main dispatch
case "${1:-help}" in
    init)      shift; cmd_init "$@" ;;
    get)       shift; cmd_get "$@" ;;
    update)    shift; cmd_update "$@" ;;
    append)    shift; cmd_append "$@" ;;
    increment) shift; cmd_increment "$@" ;;
    set)       shift; cmd_set "$@" ;;
    path)      shift; cmd_path "$@" ;;
    exists)    shift; cmd_exists "$@" ;;
    help|--help|-h) cmd_help ;;
    *) echo "Unknown command: $1" >&2; cmd_help >&2; exit 1 ;;
esac
