#!/usr/bin/env bash
#
# visual-qa-desktop - Automated visual QA in isolated virtual display
#
# Thin CLI dispatcher around `visual-qa.conf` and sourced helpers.

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

_vqa_rewritten_args=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --target=*)
            export VQA_TARGET="${1#--target=}"
            shift
            ;;
        --target)
            [[ $# -ge 2 ]] || {
                echo "ERROR: Usage: visual-qa-desktop [--target NAME] <command> [args...]" >&2
                exit 1
            }
            export VQA_TARGET="$2"
            shift 2
            ;;
        *)
            _vqa_rewritten_args+=("$1")
            shift
            ;;
    esac
done
if [[ ${#_vqa_rewritten_args[@]} -gt 0 ]]; then
    set -- "${_vqa_rewritten_args[@]}"
fi

_vqa_conf="${VQA_CONFIG:-${ROOT_DIR}/visual-qa.conf}"
[[ -f "$_vqa_conf" ]] && source "$_vqa_conf"

VQA_TARGET_NAME="${VQA_TARGET_NAME:-${VQA_TARGET:-default}}"
VQA_LAYOUT_ENV_KEY="${VQA_LAYOUT_ENV_KEY:-}"
VQA_MAP_ENV_KEY="${VQA_MAP_ENV_KEY:-}"
VQA_DEFAULT_LAYOUT_ENV="${VQA_DEFAULT_LAYOUT_ENV:-}"
VQA_SUPPORTS_LAYOUT="${VQA_SUPPORTS_LAYOUT:-}"
VQA_SUPPORTS_MAP="${VQA_SUPPORTS_MAP:-}"
VQA_SUPPORTS_BASELINE="${VQA_SUPPORTS_BASELINE:-}"
VQA_BASELINE_FIXTURES_DIR="${VQA_BASELINE_FIXTURES_DIR:-$ROOT_DIR/testdata/golden/layouts}"
VQA_BASELINE_GOLDEN_DIR="${VQA_BASELINE_GOLDEN_DIR:-}"
VQA_BASELINE_FIXTURE_GLOB="${VQA_BASELINE_FIXTURE_GLOB:-*.ron}"
VQA_AUTO_WATCH="${VQA_AUTO_WATCH:-true}"

if [[ -z "$VQA_SUPPORTS_LAYOUT" ]]; then
    if [[ -n "$VQA_LAYOUT_ENV_KEY" ]]; then
        VQA_SUPPORTS_LAYOUT="true"
    else
        VQA_SUPPORTS_LAYOUT="false"
    fi
fi
if [[ -z "$VQA_SUPPORTS_MAP" ]]; then
    if [[ -n "$VQA_MAP_ENV_KEY" ]]; then
        VQA_SUPPORTS_MAP="true"
    else
        VQA_SUPPORTS_MAP="false"
    fi
fi
if [[ -z "$VQA_SUPPORTS_BASELINE" ]]; then
    if [[ "$VQA_SUPPORTS_LAYOUT" == "true" ]]; then
        VQA_SUPPORTS_BASELINE="true"
    else
        VQA_SUPPORTS_BASELINE="false"
    fi
fi

SESSION_FILE="${VISUAL_QA_SESSION:-/tmp/visual-qa-session.json}"
SCREENSHOT_DIR=""
_OCR_CACHE_FILE="/tmp/visual-qa-ocr-cache.tsv"
_OCR_CACHE_STAMP="/tmp/visual-qa-ocr-cache.stamp"

# shellcheck source=/dev/null
. "$SCRIPT_DIR/lib/common.sh"
# shellcheck source=/dev/null
. "$SCRIPT_DIR/lib/map_ocr.sh"
# shellcheck source=/dev/null
. "$SCRIPT_DIR/lib/session.sh"
# shellcheck source=/dev/null
. "$SCRIPT_DIR/lib/interaction.sh"
# shellcheck source=/dev/null
. "$SCRIPT_DIR/lib/baseline.sh"

_usage() {
    cat <<'EOF'
Usage: visual-qa-desktop [--target NAME] <command> [args...]

Session:
  setup                              Check/install dependencies
  start [--build] [--size WxH] [--layout FILE]
                                      Start Xvfb + app + OCR pre-warm
  watch                              Open live viewer (ffplay)
  stop                               Kill app + Xvfb, clean up
  window-info                        Window geometry JSON
  map                                Current live pane/split map JSON
  status                             Session health JSON
  doctor                             Dependency + session self-check

Element Finding:
  locate "text" [options]            OCR element finder -> "X Y"
    --all                            Return all matches
    --near X Y                       Closest match to point
    --y-range MIN MAX                Filter by vertical band
    --conf N                         Min OCR confidence (default 50)
  cursor-pos                         Current cursor position

Interaction:
  click X Y                          Left click
  right-click X Y                    Right click
  double-click X Y                   Double click
  drag X1 Y1 X2 Y2 [--steps N]       Press -> interpolate -> release
  mousedown X Y [--button N]         Press and hold
  mouseup [--button N]               Release
  move X Y                           Move cursor
  key KEY                            Press key (xdotool names)
  type "text"                        Type text

High-Level:
  resize-pane "A" "B" DELTA_PX       Resize adjacent panes using live map
  assert <subcommand> [...]          Verify session state or UI invariants
  drop-tab "source" ...              Drop a tab onto a live pane/edge target
  reorder-tab "source" "anchor"      Reorder within a pane via live tab bar
  tab-transfer "source" "target"     Drag source tab into target's tab bar
  maximize ["tab name"]              Right-click tab -> Maximize pane
  restore                            Right-click tab -> Restore layout

Capture:
  screenshot [--output PATH]         Capture current state
  record start|stop                  Video capture via ffmpeg
  baseline capture|check             Golden baseline management
  cleanup [N]                        Remove old screenshot runs (keep N, default 3)
EOF
    exit 0
}

[[ $# -ge 1 ]] || _usage
[[ "$1" == "--help" || "$1" == "-h" ]] && _usage

cmd="$1"; shift
case "$cmd" in
    setup)        cmd_setup "$@" ;;
    start)        cmd_start "$@" ;;
    watch)        cmd_watch "$@" ;;
    screenshot)   cmd_screenshot "$@" ;;
    click)        cmd_click "$@" ;;
    double-click) cmd_double_click "$@" ;;
    right-click)  cmd_right_click "$@" ;;
    drag)         cmd_drag "$@" ;;
    mousedown)    cmd_mousedown "$@" ;;
    mouseup)      cmd_mouseup "$@" ;;
    move)         cmd_move "$@" ;;
    key)          cmd_key "$@" ;;
    type)         cmd_type "$@" ;;
    window-info)  cmd_window_info "$@" ;;
    map)          cmd_map "$@" ;;
    status)       cmd_status "$@" ;;
    doctor)       cmd_doctor "$@" ;;
    record)       cmd_record "$@" ;;
    baseline)     cmd_baseline "$@" ;;
    locate)       cmd_locate "$@" ;;
    cursor-pos)   cmd_cursor_pos "$@" ;;
    resize-pane)  cmd_resize_pane "$@" ;;
    assert)       cmd_assert "$@" ;;
    drop-tab)     cmd_drop_tab "$@" ;;
    reorder-tab)  cmd_reorder_tab "$@" ;;
    tab-transfer) cmd_tab_transfer "$@" ;;
    maximize)     cmd_maximize "$@" ;;
    restore)      cmd_restore "$@" ;;
    cleanup)      cmd_cleanup "$@" ;;
    stop)         cmd_stop "$@" ;;
    *)            die "Unknown command: $cmd" ;;
esac
