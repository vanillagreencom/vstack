#!/usr/bin/env bash
#
# screenshot - Capture a single screenshot of the app
#
# Location: scripts/screenshot
#
# Usage: screenshot [--no-build] [--timeout N] [--layout FILE] [--output DIR]

set -uo pipefail

fail() { echo "FAIL: $*" >&2; exit 1; }

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

_rewritten_args=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --target=*)
            export VQA_TARGET="${1#--target=}"
            shift
            ;;
        --target)
            [[ $# -ge 2 ]] || fail "Usage: screenshot [--target NAME] [--no-build] [--timeout N] [--layout FILE] [--output DIR]"
            export VQA_TARGET="$2"
            shift 2
            ;;
        *)
            _rewritten_args+=("$1")
            shift
            ;;
    esac
done
set -- "${_rewritten_args[@]}"

# Load project-specific config if available
_vqa_conf="${VQA_CONFIG:-${ROOT_DIR}/visual-qa.conf}"
[[ -f "$_vqa_conf" ]] && source "$_vqa_conf"

# Required config — must be set via visual-qa.conf or environment
_require_config() {
    local var="$1" desc="$2"
    if [[ -z "${!var:-}" ]]; then
        fail "$var not configured. Set it in visual-qa.conf or as an env var. ($desc)"
    fi
}

_require_config VQA_APP_BINARY "path to the application binary"
_require_config VQA_BUILD_CMD "command to build the application"
_require_config VQA_SCREENSHOT_ENV_KEY "env var name the app reads for screenshot output dir"

VQA_TARGET_NAME="${VQA_TARGET_NAME:-${VQA_TARGET:-default}}"
VQA_LAYOUT_ENV_KEY="${VQA_LAYOUT_ENV_KEY:-}"
VQA_DEFAULT_LAYOUT_ENV="${VQA_DEFAULT_LAYOUT_ENV:-}"
VQA_SUPPORTS_LAYOUT="${VQA_SUPPORTS_LAYOUT:-}"
if [[ -z "$VQA_SUPPORTS_LAYOUT" ]]; then
    if [[ -n "$VQA_LAYOUT_ENV_KEY" ]]; then
        VQA_SUPPORTS_LAYOUT="true"
    else
        VQA_SUPPORTS_LAYOUT="false"
    fi
fi

build_target() {
    (cd "$ROOT_DIR" && bash -lc "$VQA_BUILD_CMD")
}

binary_has_dev_screenshot_support() {
    local binary="$1"
    [[ -f "$binary" ]] || return 1
    LC_ALL=C grep -aq "$VQA_SCREENSHOT_ENV_KEY" "$binary" 2>/dev/null
}

print_stderr_diagnostics() {
    local stderr_file="$1"
    if [[ -s "$stderr_file" ]]; then
        echo "stderr tail:" >&2
        tail -20 "$stderr_file" >&2
    else
        echo "stderr: <empty>" >&2
    fi
}

report_capture_failure() {
    local binary="$1"
    local stderr_file="$2"
    local exit_code="$3"
    local stage="screenshot capture"
    local cause="App exited without writing a screenshot"
    local hint="Inspect stderr output below."

    if ! binary_has_dev_screenshot_support "$binary"; then
        stage="build/bootstrap"
        cause="Binary $binary does not include the dev-only screenshot path required by $VQA_SCREENSHOT_ENV_KEY."
        hint="Rebuild with: $VQA_BUILD_CMD, or rerun without --no-build."
    elif grep -qiE 'failed to (read|parse) layout fixture' "$stderr_file" 2>/dev/null; then
        stage="scenario/layout loading"
        cause="The requested layout fixture could not be loaded."
        hint="Check that the fixture exists and parses cleanly."
    elif grep -qiE 'failed to save screenshot|screenshot error:' "$stderr_file" 2>/dev/null; then
        stage="output path handling"
        cause="App captured a screenshot but failed to write the PNG to the output directory."
        hint="Check directory permissions and free space for the output path."
    elif grep -qiE 'X11|wayland|wl_display|xcb|surface|vulkan|wgpu|winit' "$stderr_file" 2>/dev/null; then
        stage="app startup/rendering"
        cause="App reported a display or renderer startup error before producing a screenshot."
        hint="Inspect the renderer/display error lines below."
    elif [[ "$exit_code" -eq 124 ]]; then
        stage="screenshot timeout"
        cause="App did not emit a screenshot within ${TIMEOUT}s."
        hint="If startup is expected to be slow, retry with --timeout N and inspect stderr."
    fi

    echo "FAIL: No screenshot captured" >&2
    echo "stage: $stage" >&2
    echo "cause: $cause" >&2
    echo "hint: $hint" >&2
    echo "binary: $binary" >&2
    echo "layout: ${LAYOUT:-<default>}" >&2
    echo "output_dir: $OUTPUT_DIR" >&2
    echo "exit_code: $exit_code" >&2
    print_stderr_diagnostics "$stderr_file"
    exit 1
}

TIMEOUT=6
BUILD=true
LAYOUT=""
OUTPUT_DIR=""

while [[ $# -gt 0 ]]; do
    case $1 in
        --no-build) BUILD=false; shift ;;
        --timeout)  TIMEOUT="$2"; shift 2 ;;
        --layout)   LAYOUT="$2"; shift 2 ;;
        --output)   OUTPUT_DIR="$2"; shift 2 ;;
        -h|--help)
            echo "Usage: screenshot [--target NAME] [--no-build] [--timeout N] [--layout FILE] [--output DIR]"
            echo "  Captures a screenshot of ${VQA_TARGET_NAME}."
            echo "  --no-build expects the binary to already be built."
            exit 0
            ;;
        *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
done

if [[ -n "$LAYOUT" && "$VQA_SUPPORTS_LAYOUT" != "true" ]]; then
    fail "VQA_TARGET=${VQA_TARGET_NAME} does not support --layout"
fi

# Default output directory: testdata/screenshots/<run-id>/
if [[ -z "$OUTPUT_DIR" ]]; then
    OUTPUT_DIR="$ROOT_DIR/testdata/screenshots/${VISUAL_QA_RUN_ID:-$(date +%Y%m%d-%H%M%S)}"
fi
mkdir -p "$OUTPUT_DIR" || fail "Failed to create output directory: $OUTPUT_DIR"

# Resolve timeout command (macOS: gtimeout from coreutils)
TIMEOUT_CMD="timeout"
if ! command -v timeout &>/dev/null; then
    if command -v gtimeout &>/dev/null; then
        TIMEOUT_CMD="gtimeout"
    else
        fail "'timeout' not found (install coreutils)"
    fi
fi

cd "$ROOT_DIR"

# Build
if [[ "$BUILD" == "true" ]]; then
    if ! build_target 2>&1; then
        fail "build failed"
    fi
fi

BINARY="$VQA_APP_BINARY"
if [[ ! -x "$BINARY" ]]; then
    fail "Binary not found at $BINARY"
fi

# Set env vars
SCREENSHOT_ENV=("${VQA_SCREENSHOT_ENV_KEY}=$OUTPUT_DIR")
if [[ -n "$VQA_DEFAULT_LAYOUT_ENV" ]]; then
    DEFAULT_ENV=()
    read -r -a DEFAULT_ENV <<< "$VQA_DEFAULT_LAYOUT_ENV"
    SCREENSHOT_ENV+=("${DEFAULT_ENV[@]}")
fi
if [[ -n "$LAYOUT" ]]; then
    if [[ ! -f "$LAYOUT" ]]; then
        fail "Layout fixture not found: $LAYOUT"
    fi
    [[ -n "$VQA_LAYOUT_ENV_KEY" ]] || fail "VQA_LAYOUT_ENV_KEY not configured but --layout was passed"
    SCREENSHOT_ENV+=("${VQA_LAYOUT_ENV_KEY}=$LAYOUT")
fi

# Require a display (macOS always has one)
if [[ "$(uname -s)" != "Darwin" ]] && [[ -z "${DISPLAY:-}" ]] && [[ -z "${WAYLAND_DISPLAY:-}" ]]; then
    echo "FAIL: No display available" >&2
    echo "stage: display setup" >&2
    echo "cause: Neither DISPLAY nor WAYLAND_DISPLAY is set." >&2
    echo "hint: Run inside a desktop session or use visual-qa start for an isolated Xvfb session." >&2
    exit 1
fi

# Run — the app captures a screenshot and exits on its own
STDERR_FILE=$(mktemp)
trap 'rm -f "$STDERR_FILE"' EXIT

run_exit=0
if env "${SCREENSHOT_ENV[@]}" "$TIMEOUT_CMD" "$TIMEOUT" "$BINARY" 2>"$STDERR_FILE"; then
    run_exit=0
else
    run_exit=$?
fi

# Check for panics
if grep -qiE 'panicked|panic!' "$STDERR_FILE" 2>/dev/null; then
    echo "FAIL: Runtime panic:" >&2
    grep -iE 'panicked|panic!' "$STDERR_FILE" | head -3 >&2
    exit 1
fi

# Find the captured screenshot — app prints "screenshot: <path>" to stderr
SCREENSHOT=$(grep "^screenshot: " "$STDERR_FILE" 2>/dev/null | head -1 | sed 's/^screenshot: //')
if [[ -z "$SCREENSHOT" ]]; then
    # Fallback: find newest PNG in output dir
    SCREENSHOT=$(find "$OUTPUT_DIR" -name "*.png" -newer "$STDERR_FILE" | head -1)
fi

if [[ -z "$SCREENSHOT" ]] || [[ ! -f "$SCREENSHOT" ]]; then
    report_capture_failure "$BINARY" "$STDERR_FILE" "$run_exit"
fi

echo "$SCREENSHOT"
